# App Configuration
PORT=3000
NODE_ENV=development
API_PREFIX=api/v1
APP_URL=http://localhost:3000

# Database Configuration (PostgreSQL)
# For local Docker:
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/lumiq?schema=public"

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=super-secret-jwt-key-replace-in-production-12345
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=super-secret-refresh-jwt-key-replace-in-production-12345
JWT_REFRESH_EXPIRATION=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_51...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=usd

# AWS S3 / MinIO Configuration
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadminpassword
AWS_REGION=us-east-1
AWS_S3_BUCKET=lumiq-storage
AWS_S3_ENDPOINT=http://localhost:9000
AWS_S3_FORCE_PATH_STYLE=true

# Resend Email Configuration
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@lumiq.com

# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Maps Provider (Nominatim URL)
NOMINATIM_USER_AGENT=LumiqEVMarketplace/1.0
